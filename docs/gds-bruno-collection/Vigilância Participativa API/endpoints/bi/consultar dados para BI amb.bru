meta {
  name: consultar dados para BI amb
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/syndromic-classification/reports/bi-export-scores?startDate=2026-04-28&endDate=2026-04-30&topScore=true
  body: none
  auth: none
}

params:query {
  startDate: 2026-04-28
  endDate: 2026-04-30
  topScore: true
  ~isAboveThreshold: true
  ~onlySymptoms: true
}

headers {
  x-api-key: {{chave_api_bi}}
}
