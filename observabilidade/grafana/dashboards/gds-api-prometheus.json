          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum(rate(http_server_duration_milliseconds_count{job=~\"$otel_service\"}[$__rate_interval]))",
