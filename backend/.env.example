DATABASE_URL="postgresql://gds_user:gds_password@localhost:5432/gds_db"

# Mailer (SMTP) - obrigatório para "Esqueci minha senha"
# Valores padrão para uso local com Papercut (https://github.com/ChangemakerStudios/Papercut-SMTP)
MAILER_SMTP_ADDRESS=localhost
MAILER_EMAIL=local@localhost
MAILER_PASSWORD=local
MAILER_SMTP_PORT=25

# URL do frontend (para link de redefinição de senha no email)
FRONTEND_URL=http://localhost:5173

# OpenTelemetry (opcional) — só ativa o SDK se pelo menos um endpoint OTLP estiver definido.
# Local com stack em ../observabilidade (Grafana OTEL LGTM):
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_SERVICE_NAME=gds-backend
# Recomendado pelo Prometheus OTLP (rótulos job / instance):
# OTEL_SERVICE_INSTANCE_ID=dev-machine-1
# Export de métricas (ms); padrão SDK costuma ser ~60000
# OTEL_METRIC_EXPORT_INTERVAL=15000
# Logs Pino níveis error/fatal → OTLP → Loki (mesmo collector). Desligar só isto:
# OTEL_EXPORT_ERROR_LOGS_TO_LOKI=false
# Desligar: OTEL_SDK_DISABLED=true

# Classificação sindrômica (V1): qual tipo de report entra no cálculo de score.
# POSITIVE (padrão se omitido) | NEGATIVE. Em produção costuma ser NEGATIVE.
# SYNDROMIC_CLASSIFICATION_REPORT_TYPE=NEGATIVE